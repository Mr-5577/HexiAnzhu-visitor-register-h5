{
  "pages": [
    //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
    {
      "path": "pages/register/index",
      "style": {
        "navigationBarTitleText": "来访登记"
      }
    },
    {
      "path": "pages/record/index",
      "style": {
        "navigationBarTitleText": "来访记录"
      }
    },
    {
      "path": "pages/check-in/index",
      "style": {
        "navigationBarTitleText": "签到中心"
      }
    },
    {
      "path": "pages/check-in/sginIn",
      "style": {
        "navigationBarTitleText": "签到"
      }
    },
    {
      "path": "pages/login/autoLogin",
      "style": {
        "navigationBarTitleText": "自动登录",
        "navigationStyle": "custom" // 启用自定义导航栏
      }
    },
    {
      "path": "pages/register/success",
      "style": {
        "navigationBarTitleText": "登记成功"
      }
    },
    {
      "path": "pages/record/record-detail",
      "style": {
        "navigationBarTitleText": "来访详情"
      }
    },
    {
      "path": "pages/check-in/sort",
      "style": {
        "navigationBarTitleText": "排序"
      }
    },
    {
      "path": "pages/check-in/list",
      "style": {
        "navigationBarTitleText": "签到列表"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "和喜安筑",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8",
    "rpxCalcMaxDeviceWidth": 750, // 设计稿宽度
    "rpxCalcBaseDeviceWidth": 375, // 开发设备宽度
    "rpxCalcIncludeWidth": 750
  },
  "tabBar": {
    "color": "#7A7E83",
    "selectedColor": "#007AFF",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "white",
    "fontSize": "10px",
    "list": [
      {
        "pagePath": "pages/register/index",
        "iconPath": "static/images/register.png",
        "selectedIconPath": "static/images/register-selected.png",
        "text": "来访登记"
      },
      {
        "pagePath": "pages/record/index",
        "iconPath": "static/images/record.png",
        "selectedIconPath": "static/images/record-selected.png",
        "text": "来访记录"
      },
      {
        "pagePath": "pages/check-in/index",
        "iconPath": "static/images/check-in.png",
        "selectedIconPath": "static/images/check-in-selected.png",
        "text": "签到中心"
      }
    ]
  },
  "uniIdRouter": {},
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@/uni_modules/uni-$1/uni-$1.vue"
    }
  }
}
